<Window x:Class="WpfApp3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp3"
        mc:Ignorable="d"
        Title="MainWindow" Height="300" Width="300">
    <StackPanel Margin="10">
        <TextBlock Text="Város"></TextBlock>
        <TextBox Text="{Binding Varos}"></TextBox>
        <TextBlock Text="Hőmérséklet"></TextBlock>
        <TextBox Text="{Binding Homerseklet}"></TextBox>
        <TextBlock Text="Páratartalom"></TextBlock>
        <TextBox Text="{Binding Paratartalom}"></TextBox>
        <Button Content="Értékelés" Name="ertekeles" Click="ertekeles_Click" Margin="10"></Button>
        <Button Content="Hőmérséklet növelése" Name="noveles" Click="noveles_Click"  Margin="10"></Button>
        <TextBlock Name="hoerzet" FontSize="14"></TextBlock>
        <TextBlock Name="idojaras" FontSize="14"></TextBlock>
    </StackPanel>
</Window>
