<Window x:Class="IKT2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IKT2"
        mc:Ignorable="d"
        Title="Főablak" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Menu>
            <MenuItem Header="Adatok" FontSize="15">
                <MenuItem Header="Felvitel" Click="AddMark"/>
                <MenuItem Header="Statisztika"/>
                <MenuItem Header="Jegy keresése"/>
            </MenuItem>

            <MenuItem Header="Névjegy" Click="ShowCreator" FontSize="15"></MenuItem>
            <MenuItem Header="Kilépés" Click="Quit" FontSize="15"/>
        </Menu>
        <Label Content="Üdvözöllek a jegykezelő alkalmazásban!" Grid.Row="1" FontSize="25" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"></Label>
        <Image Source="icon.jpg" Grid.Row="2"/>
    </Grid>
</Window>
