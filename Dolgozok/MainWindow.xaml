<Window x:Class="Dolgozok.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Dolgozok"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="600">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Label Grid.ColumnSpan="2" Content="Dolgozói adatok" FontSize="30" HorizontalAlignment="Center" FontWeight="Bold"></Label>
        <ListBox Grid.Row="1"></ListBox>
        <StackPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Width="200" Height="30" Content="Adatok betöltése" Margin="10" Click="datas_Click"></Button>
            <Button Width="200" Height="30" Content="Átlagbér" Margin="10" Click="averageWage_Click"></Button>
            <Button Width="200" Height="30" Content="Legnagyobb bérű dolgozó" Margin="10" Click="maxWage_Click"></Button>
            <Button Width="200" Height="30" Content="Nemek szerinti megosztás" Margin="10" Click="sex_Click"></Button>
            <Button Width="200" Height="30" Content="Részlegenkénti statisztika" Margin="10" Click="statistics_Click"></Button>
            <Button Width="200" Height="30" Content="Legrégebbi dolgozó" Margin="10" Click="oldest_Click"></Button>
        </StackPanel>
    </Grid>
</Window>
