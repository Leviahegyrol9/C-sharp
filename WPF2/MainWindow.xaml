<Window x:Class="WPF2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF2"
        mc:Ignorable="d"
        Title="Jóváhagyás" Height="200" Width="300">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <CheckBox Name="elfogad" Content="Elfogadom a feltételeket" Margin="10"></CheckBox>
        <Button Content="Tovább" Width="150" Height="40">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="IsEnabled" Value="False"></Setter>
                    <Setter Property="Background" Value="LightGray"></Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=elfogad}" Value="True">
                            <Setter Property="IsEnabled" Value="True"></Setter>
                            <Setter Property="Background" Value="LightGreen"></Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </StackPanel>
</Window>
