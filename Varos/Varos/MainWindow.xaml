<Window x:Class="Varos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Varos"
        mc:Ignorable="d"
        Title="MainWindow" Height="250" Width="800">
    <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Center">
            <ComboBox Width="150" Height="30" Margin="5" Name="lista">
                <ComboBoxItem Content="Budapest"></ComboBoxItem>
                <ComboBoxItem Content="Szeged"></ComboBoxItem>
                <ComboBoxItem Content="Makó"></ComboBoxItem>
                <ComboBoxItem Content="Ózd"></ComboBoxItem>
                <ComboBoxItem Content="Győr"></ComboBoxItem>
            </ComboBox>
            <TextBox Width="150" Height="30" Margin="10" Name="ujvaros"></TextBox>
            <Button Width="150" Height="30" Content="Új város felvitele" Name="hozzaad" Click="hozzaad_Click" Margin="10"></Button>
            <Button Width="150" Height="30" Content="Város törlese" Name="torles" Click="torles_Click" Margin="10"></Button>
        </StackPanel>
    </Grid>
</Window>
