<UserControl x:Class="WpfApp2.UserControls.Jegyzetiras"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfApp2.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel Margin="10">
        <TextBlock Text="Írd be a jegyzetet:" Margin="10"></TextBlock>
        <TextBox Height="140" Margin="10" Name="jegyzet" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"></TextBox>
        <Button Content="Mentés" Height="25" Width="150" HorizontalAlignment="Left" Name="mentes" Click="mentes_Click" Margin="10"></Button>
    </StackPanel>
</UserControl>
