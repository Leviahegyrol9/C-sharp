<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        Title="MainWindow" Height="300" Width="400">
    <StackPanel Margin="10">
        <TextBlock Text="Termék neve:" Margin="5"></TextBlock>
        <TextBox Margin="5" Text="{Binding Newproduct.Name}"></TextBox>
        <TextBlock Text="Ár (Ft):" Margin="5"></TextBlock>
        <TextBox Margin="5" Text="{Binding Newproduct.Price}"></TextBox>
        <Button Content="Hozzáadás" Name="hozzaad" Click="hozzaad_Click" Margin="5"></Button>
        <ListBox ItemsSource="{Binding Listproduct}" SelectedItem="{Binding Newproduct}"></ListBox>
    </StackPanel>
</Window>
