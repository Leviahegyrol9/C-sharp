<Window x:Class="Vérnyomás.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vérnyomás"
        xmlns:viewModel="clr-namespace:Vérnyomás.ViewModel"
        mc:Ignorable="d"
        Title="MainWindow" Height="400" Width="600">
    <Window.DataContext>
        <viewModel:NyomasViewModel/>
    </Window.DataContext>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Label FontSize="30" Content="Vérnyomás és pulzus kalkulátor" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.ColumnSpan="2"></Label>
        <Label Grid.Row="1" FontSize="25" Content="Életkor:" HorizontalAlignment="Center" VerticalAlignment="Center"></Label>
        <Label Grid.Row="2" FontSize="25" Content="Testsúly:" HorizontalAlignment="Center" VerticalAlignment="Center"></Label>
        <Label Grid.Row="3" FontSize="25" Content="Aktivitás szintje (0-3):" HorizontalAlignment="Center" VerticalAlignment="Center"></Label>
        <Label Grid.Row="6" FontSize="25" Content="Kedvező pulzusérték:" HorizontalAlignment="Center" VerticalAlignment="Center"></Label>
        <Label Grid.Row="7" FontSize="25" Content="Kedvező vérnyomásérték:" HorizontalAlignment="Center" VerticalAlignment="Center"></Label>

        <TextBox Grid.Row="1" Grid.Column="1" Width="200" Height="30" Text="{Binding Kor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Row="2" Grid.Column="1" Width="200" Height="30" Text="{Binding Suly, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Row="3" Grid.Column="1" Width="200" Height="30" Text="{Binding Szint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Row="6" Grid.Column="1" Width="200" Height="30" Text="{Binding Pulzus, Mode=OneWay}" IsReadOnly="True"></TextBox>
        <TextBox Grid.Row="7" Grid.Column="1" Width="200" Height="30" Text="{Binding Vernyomas, Mode=OneWay}" IsReadOnly="True"></TextBox>

        <Button Grid.Row="4" Grid.ColumnSpan="2" Width="200" Height="30" Content="Számolás" FontSize="20" Command="{Binding CalculateCommand}"></Button>
    </Grid>
</Window>
