<Window x:Class="Etterem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Etterem"
        mc:Ignorable="d"
        Title="MainWindow" Height="650" Width="600">
    <Grid Margin="10">
        <DockPanel>
            <Menu DockPanel.Dock="Top">
                <MenuItem Header="Vendégadatok kezelése">
                    <MenuItem Header="Új vendég rögzítése" Name="ujvendeg" Click="ujvendeg_Click"></MenuItem>
                    <MenuItem Header="Vendégstatisztika" Name="stat" Click="stat_Click"></MenuItem>
                    <MenuItem Header="Ételstatisztika és bevétel" Name="statbev" Click="statbev_Click"></MenuItem>
                </MenuItem>
                <MenuItem Header="Kilépés" Name="kilepes" Click="kilepes_Click"></MenuItem>
            </Menu>
        </DockPanel>
        <ContentControl Name="tartalom"></ContentControl>
    </Grid>
</Window>
