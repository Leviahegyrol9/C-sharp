<Window x:Class="WpfApp8.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp8"
        mc:Ignorable="d"
        Title="MainWindow" Height="420" Width="600">
    <Window.DataContext>
        <local:Hitel/>
    </Window.DataContext>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"></RowDefinition>
            <RowDefinition Height="70"></RowDefinition>
            <RowDefinition Height="70"></RowDefinition>
            <RowDefinition Height="70"></RowDefinition>
            <RowDefinition Height="70"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Label Content="Hitelkalkulátor" FontSize="25" FontWeight="Bold" Grid.ColumnSpan="2" HorizontalAlignment="Center"></Label>
        <TextBlock Text="Havi törlesztőrészlet (Ft)" FontSize="20" FontWeight="Bold" Grid.Row="1" HorizontalAlignment="Center"></TextBlock>
        <TextBlock Text="Éves kamatláb (%)" FontSize="20" FontWeight="Bold" Grid.Row="2" HorizontalAlignment="Center"></TextBlock>
        <TextBlock Text="Törlesztés időtartama (év)" FontSize="20" FontWeight="Bold" Grid.Row="3" HorizontalAlignment="Center"></TextBlock>
        <TextBlock Text="Felvető hitelösszeg (Ft)" FontSize="20" FontWeight="Bold" Grid.Row="4" HorizontalAlignment="Center"></TextBlock>

        <TextBox Grid.Row="1" Grid.Column="1" Width="200" Height="30" Text="{Binding Torleszto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Row="2" Grid.Column="1" Width="200" Height="30" Text="{Binding Kamatlab, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Row="3" Grid.Column="1" Width="200" Height="30" Text="{Binding Evek, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Row="4" Grid.Column="1" Width="200" Height="30" Text="{Binding Hitelosszeg, Mode=OneWay}"></TextBox>
    </Grid>
</Window>
