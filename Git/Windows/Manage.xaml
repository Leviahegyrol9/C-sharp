<Window x:Class="Git.Windows.Manage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Git.Windows"
        mc:Ignorable="d"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#2b7a78"
        Loaded="Manage_Loaded"
        Closing="Manage_Closing"
        Title="Git Hub Manager"
        Height="450" Width="800">
    
    <Window.Resources>
        <Style TargetType="Button">

            <Setter Property="Background" Value="#def2f1"/>
            <Setter Property="Foreground" Value="#17252a"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#17252a"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Height" Value="35"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                    <Setter Property="Background" Value="#17252a"/>
                    <Setter Property="Foreground" Value="#def2f1"/>
                </Trigger>
            </Style.Triggers>

        </Style>
    </Window.Resources>
    
    <Grid Margin="10" Name="mainGrid">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Button Grid.Row="1"
            Width="100"
            Content="Push"
            VerticalAlignment="Top"
            Margin="150,0,0,0"
            Click="Push">
        </Button>

        <Button Grid.Row="1" Grid.Column="1"
            Width="100"
            Content="Pull"
            VerticalAlignment="Top"
            Margin="0,0,150,0"
            Click="Pull">
        </Button>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Button
                Margin="0,0,20,0"
                Width="180"
                Content="Új fájl kiválasztása"
                Click="NewFile">
            </Button>

            <ProgressBar
                Name="progressBar"
                Width="180"
                Height="20"
                Minimum="0"
                Maximum="100"
                Foreground="#17252a"
                Background="#def2f1"
                BorderThickness="0"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">

                <ProgressBar.Template>

                    <ControlTemplate TargetType="ProgressBar">

                        <Grid ClipToBounds="True">

                            <!-- háttér -->
                            <Border
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"/>

                            <!-- track -->
                            <Rectangle x:Name="PART_Track"/>

                            <!-- kitöltés -->
                            <Grid x:Name="PART_Indicator"
                                ClipToBounds="True"
                                HorizontalAlignment="Left">

                                <Rectangle
                                    Fill="{TemplateBinding Foreground}"
                                    RadiusX="8"
                                    RadiusY="8"/>

                                <!-- indeterminate animációhoz -->
                                <Rectangle x:Name="Animation"
                                   Fill="{TemplateBinding Foreground}"
                                   RadiusX="8"
                                   RadiusY="8"
                                   RenderTransformOrigin="0.5,0.5">

                                    <Rectangle.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </Rectangle.RenderTransform>

                                </Rectangle>

                            </Grid>

                        </Grid>

                    </ControlTemplate>

                </ProgressBar.Template>

            </ProgressBar>
        </StackPanel>
    </Grid>
</Window>
