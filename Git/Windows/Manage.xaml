<Window x:Class="Git.Windows.Manage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Git.Windows"
        mc:Ignorable="d"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#f05133"
        Loaded="Manage_Loaded"
        Title="Git Hub Manager"
        Height="450" Width="800">
    
    <Window.Resources>
        <Style TargetType="Button">

            <Setter Property="Background" Value="#f05133"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Height" Value="35"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                    <Setter Property="Background" Value="Black"/>
                    <Setter Property="Foreground" Value="#f05133"/>
                </Trigger>
            </Style.Triggers>

        </Style>
    </Window.Resources>
    
    <Grid Margin="10" Name="mainGrid">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Button Grid.Row="1"
            Width="100"
            Height="35"
            Content="Push"
            FontSize="20"
            VerticalAlignment="Top"
            Margin="100,0,0,0"
            Click="Push">
        </Button>

        <Button Grid.Row="1" Grid.Column="1"
            Width="100"
            Height="35"
            Content="Pull"
            FontSize="20"
            VerticalAlignment="Top"
            Margin="0,0,100,0"
            Click="Pull">
        </Button>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Name="panel">
            <Button
                Margin="0,0,50,0"
                Width="200"
                Height="35"
                Content="Új fájl kiválasztása"
                FontSize="20"
                Click="NewFile">
            </Button>

            <ProgressBar
             Name="progressBar"
             Height="18"
             Width="250"
             BorderThickness="0">

                <ProgressBar.Template>
                    <ControlTemplate TargetType="ProgressBar">

                        <Grid ClipToBounds="True">

                            <!-- háttér -->
                            <Border Background="Black"
                        CornerRadius="9"/>

                            <!-- kitöltés -->
                            <Border x:Name="PART_Indicator"
                        Background="#4CAF50"
                        HorizontalAlignment="Left"
                        CornerRadius="9"
                        Width="0"/>

                        </Grid>

                        <ControlTemplate.Triggers>

                            <!-- VALUE → WIDTH -->
                            <Trigger Property="IsIndeterminate" Value="False">
                                <Setter TargetName="PART_Indicator"
                            Property="Width"
                            Value="{Binding Value,
                            RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </ProgressBar.Template>

            </ProgressBar>
        </StackPanel>
    </Grid>
</Window>
