<Window x:Class="Berek.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Berek"
        mc:Ignorable="d"
        Title="MainWindow" Height="200" Width="500">
    <Window.DataContext>
        <local:Ber/>
    </Window.DataContext>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Label Grid.Row="0" FontSize="20" Content="Bruttó fizetés"></Label>
        <Label Grid.Row="1" FontSize="20" Content="Levonások mértéke"></Label>
        <Label Grid.Row="2" FontSize="20" Content="Nettó fizetés"></Label>
        <Label Grid.Row="3" FontSize="20" Content="Levonások összege"></Label>

        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Brutto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Levonasok, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Netto, Mode=OneWay}"></TextBox>
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Osszeg, Mode=OneWay}"></TextBox>
    </Grid>
</Window>
