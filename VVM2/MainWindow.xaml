<Window x:Class="VVM3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VVM3"
        mc:Ignorable="d"
        Title="MainWindow" Height="550" Width="500">
    <Window.DataContext>
        <local:PasswordViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"></RowDefinition>
            <RowDefinition Height="2*"></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Jelszóelemző" FontSize="25" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"></TextBlock>
            <TextBox Width="300" Height="30" Text="{Binding Pwd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <Button Width="200" Height="35" Content="Elemzés" Margin="10" Command="{Binding AnalyzeCommand}"></Button>
            <Button Width="200" Height="35" Content="Törlés" Margin="10" Command="{Binding ClearCommand}"></Button>

            <Border BorderBrush="Black" BorderThickness="2" CornerRadius="10" Width="300" Height="200">
                <StackPanel>
                    <TextBlock Text="{Binding PasswordLength}" Margin="10"></TextBlock>
                    <TextBlock Text="{Binding ContainsNumber}" Margin="10"></TextBlock>
                    <TextBlock Text="{Binding ContainsUppercase}" Margin="10"></TextBlock>
                    <TextBlock Text="{Binding PasswordStrength}" Margin="10"></TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
