<Window x:Class="IKT.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IKT"
        mc:Ignorable="d"
        Title="Számlázó program" Height="498" Width="800">
    <Grid Margin="10,10,10,7" Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Grid.Column="0" Content="Termék neve" FontSize="16" FontWeight="Bold" VerticalContentAlignment="Center"></Label>
        <Label Grid.Column="1" Content="Nettó ár" FontSize="16" FontWeight="Bold" VerticalContentAlignment="Center" Margin="0,0,380,0"/>
        <TextBox Grid.Row="1" Width="180" Height="30" HorizontalAlignment="Center" x:Name="name" Margin="0,25,0,25"/>
        <TextBox Grid.Column="1" Width="180" Height="30" HorizontalAlignment="Left" x:Name="netto" Margin="10,25,0,25" Grid.Row="1"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Grid.ColumnSpan="2" Margin="180,0,0,0">
            <Button Name="add" Width="120" Height="30" Margin="10" Content="Hozzáad" Click="add_Click"></Button>
            <Button Name="delete" Width="120" Height="30" Margin="10" Content="Töröl" Click="delete_Click"></Button>
            <Button Name="calculate" Width="120" Height="30" Margin="10" Content="Számol" Click="calculate_Click"></Button>
        </StackPanel>
        <ListBox Grid.Row="3" x:Name="productList" Margin="192,2,192,0" Grid.ColumnSpan="2" Height="220"/>
        <Label Grid.Column="1" Content="Darabszám" FontSize="16" FontWeight="Bold" VerticalContentAlignment="Center" Margin="190,0,190,0"/>
        <Label Grid.Column="1" Content="Bruttó ár" FontSize="16" FontWeight="Bold" VerticalContentAlignment="Center" Margin="390,0,-10,0"/>
        <TextBox Grid.Column="1" Width="180" Height="30" HorizontalAlignment="Center" x:Name="quantity" Margin="0,25,0,25" Grid.Row="1"/>
        <TextBox Grid.Column="1" Width="180" Height="30" HorizontalAlignment="Left" x:Name="brutto" IsReadOnly="True" Margin="390,25,0,25" Grid.Row="1"/>
    </Grid>
</Window>
