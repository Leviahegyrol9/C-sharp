<Window x:Class="WpfApp4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp4"
        mc:Ignorable="d"
        Title="MainWindow" Height="300" Width="400">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <ComboBox Grid.Row="0" Width="250" Height="30" Margin="10" Name="atvaltas1">
            <ComboBoxItem Content="cm"></ComboBoxItem>
            <ComboBoxItem Content="m"></ComboBoxItem>
            <ComboBoxItem Content="km"></ComboBoxItem>
            <ComboBoxItem Content="inch"></ComboBoxItem>
        </ComboBox>
        <ComboBox Grid.Row="1" Width="250" Height="30" Margin="10" Name="atvaltas2">
            <ComboBoxItem Content="cm"></ComboBoxItem>
            <ComboBoxItem Content="m"></ComboBoxItem>
            <ComboBoxItem Content="km"></ComboBoxItem>
            <ComboBoxItem Content="inch"></ComboBoxItem>
        </ComboBox>
        <TextBox Width="200" Height="30" Name="atvaltando" Grid.Row="2" Margin="10"></TextBox>
        <Button Width="200" Height="30" Margin="10" Content="Átváltás" Name="atvalt" Click="atvalt_Click" Grid.Row="3"></Button>
        <TextBox Grid.Row="4" Name="eredmeny" Width="200" Height="30" Margin="10" HorizontalAlignment="Center"></TextBox>
    </Grid>
</Window>
