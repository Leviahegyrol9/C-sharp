<Window x:Class="Orai.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Orai"
        mc:Ignorable="d"
        Title="MainWindow" Height="300" Width="300">
    <StackPanel Margin="10">
        <Label Content="Táv (km)"></Label>
        <TextBox Name="kmTb" Text="{Binding Km}"></TextBox>
        <Label Content="Idő (perc)"></Label>
        <TextBox Name="timeTb" Text="{Binding Minute}"></TextBox>
        <Button Content="Kiértékelés" Name="kiertekeles" Click="kiertekeles_Click" Margin="0 10 0 0"></Button>
        <Button Content="Táv csökkentése" Name="csokkentes" Click="csokkentes_Click" Margin="0 10 0 0"></Button>
        <Label Name="avgSpeed"></Label>
        <Label Name="info"></Label>
    </StackPanel>
</Window>
