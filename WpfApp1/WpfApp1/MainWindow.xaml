<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="400" Width="450">
    <Grid Margin="10" Name="maingrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <GroupBox Grid.Row="0" Header="Cég tipusa" Margin="10">
            <StackPanel Orientation="Horizontal">
                <RadioButton Name="rbalap" Content="Alap" IsChecked="True" Margin="5"></RadioButton>
                <RadioButton Name="rbgyarto" Content="Gyarto cég" Margin="5"></RadioButton>
                <RadioButton Name="rbkereskedlmi" Content="Kereskedelmi cég" Margin="5"></RadioButton>
            </StackPanel>
        </GroupBox>
        <StackPanel Grid.Row="1" Name="mains">
            <GroupBox Header="Alapadatok" Margin="10">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Név:"></TextBlock>
                    <TextBox  Grid.Row="0" Grid.Column="1" Name="tbNev" ></TextBox>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Alkalmazottak száma:"></TextBlock>
                    <TextBox  Grid.Row="1" Grid.Column="1" Name="tbAlk" ></TextBox>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Név:"></TextBlock>
                    <TextBox  Grid.Row="2" Grid.Column="1"  Name="tbBev"></TextBox>
                </Grid>
            </GroupBox>
            <GroupBox Header="Cég cég adatai" Margin="10" Name="gbceg" Visibility="Collapsed">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Név:"></TextBlock>
                    <TextBox  Grid.Row="0" Grid.Column="1" Name="tbNev2" ></TextBox>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Alkalmazottak száma:"></TextBlock>
                    <TextBox  Grid.Row="1" Grid.Column="1" Name="tbAlk2" ></TextBox>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Név:"></TextBlock>
                    <TextBox  Grid.Row="2" Grid.Column="1"  Name="tbBev2"></TextBox>
                </Grid>
            </GroupBox>
            <GroupBox Header="Kereskedelmi cég adatai" Margin="10" Name="gbkereskedelmi" Visibility="Collapsed">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Név:"></TextBlock>
                    <TextBox  Grid.Row="0" Grid.Column="1" Name="tbNev3" ></TextBox>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Alkalmazottak száma:"></TextBlock>
                    <TextBox  Grid.Row="1" Grid.Column="1" Name="tbAlk3" ></TextBox>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Név:"></TextBlock>
                    <TextBox  Grid.Row="2" Grid.Column="1"  Name="tbBev3"></TextBox>
                </Grid>
            </GroupBox>
        </StackPanel>
        <StackPanel Grid.Row="2">
            <Button Content="Számítás" Click="szamitas_Click" Margin="10"></Button>
            <TextBlock Name="tbEredemeny" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center"></TextBlock>
        </StackPanel>
    </Grid>
</Window>
