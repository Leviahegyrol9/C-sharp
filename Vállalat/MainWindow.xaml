<Window x:Class="Vállalat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vállalat"
        xmlns:viewModel="clr-namespace:Vállalat.ViewModel"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="470">
    <Window.DataContext>
        <viewModel:VallalatViewModel/>
    </Window.DataContext>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Content="Értekesítési bevétel (Ft):" FontSize="16"></Label>
        <Label Grid.Row="1" Content="Egyéb bevétel (Ft):" FontSize="16"></Label>
        <Label Grid.Row="2" Content="Alkalmazottak bére (Ft):" FontSize="16"></Label>
        <Label Grid.Row="3" Content="Felmerült költségek (Ft):" FontSize="16"></Label>
        <Label Grid.Row="5" Grid.ColumnSpan="2" Content="Vállalat eredményadatai (Ft):" HorizontalContentAlignment="Center" FontWeight="Bold" FontSize="20" FontStyle="Italic"></Label>
        <Label Grid.Row="6" Content="Összes bevétel (Ft):" FontSize="16"></Label>
        <Label Grid.Row="7" Content="Összes költség (Ft):" FontSize="16"></Label>
        <Label Grid.Row="8" Content="Adózás előtti eredmény (Ft):" FontSize="16"></Label>
        <Label Grid.Row="9" Content="Befizetett adó (Ft):" FontSize="16"></Label>
        <Label Grid.Row="10" Content="Adózott eredmény (Ft):" FontSize="16"></Label>

        <TextBox Grid.Row="0" Grid.Column="1" Width="200" Height="25" Text="{Binding Bevetel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Row="1" Grid.Column="1" Width="200" Height="25" Text="{Binding Egyeb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Row="2" Grid.Column="1" Width="200" Height="25" Text="{Binding Bere, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Row="3" Grid.Column="1" Width="200" Height="25" Text="{Binding Koltsegek, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        
        <TextBlock Grid.Row="6" Grid.Column="1" Width="200" Height="25" Text="{Binding OBevetel}"></TextBlock>
        <TextBlock Grid.Row="7" Grid.Column="1" Width="200" Height="25" Text="{Binding OKoltseg}"></TextBlock>
        <TextBlock Grid.Row="8" Grid.Column="1" Width="200" Height="25" Text="{Binding AElotti}"></TextBlock>
        <TextBlock Grid.Row="9" Grid.Column="1" Width="200" Height="25" Text="{Binding Ado}"></TextBlock>
        <TextBlock Grid.Row="10" Grid.Column="1" Width="200" Height="25" Text="{Binding AEredmeny}"></TextBlock>

        <Button Grid.Row="4" Content="Számolás" Width="150" Height="25" Command="{Binding CalculateCommand}"></Button>
    </Grid>
</Window>
