<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="350" Width="400">
    <StackPanel Margin="10">
        <Label Content="My text" Margin="10" FontFamily="{Binding ElementName=betutipus, Path=Text}" FontWeight="{Binding ElementName=betustilus_1, Path=Text}" FontStyle="{Binding ElementName=betustilus_2, Path=Text}"></Label>
        <ComboBox Name="betutipus" SelectedIndex="0">
            <ComboBoxItem>Arial</ComboBoxItem>
            <ComboBoxItem>Courier New</ComboBoxItem>
        </ComboBox>
        <ComboBox Name="betustilus_1" SelectedIndex="0" Margin="5">
            <ComboBoxItem>Normal</ComboBoxItem>
            <ComboBoxItem>Bold</ComboBoxItem>
        </ComboBox>
        <ComboBox Name="betustilus_2" SelectedIndex="0" Margin="5">
            <ComboBoxItem>Normal</ComboBoxItem>
            <ComboBoxItem>Italic</ComboBoxItem>
        </ComboBox>
    </StackPanel>
</Window>
