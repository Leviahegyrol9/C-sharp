<Window x:Class="WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="250" Width="650">
    <Grid Margin="10">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label FontWeight="Bold" Content="10.c osztály tanulói"></Label>
            <ListBox Name="listBox" Margin="20 0 0 0">
                <ListBoxItem Content="Péter"></ListBoxItem>
                <ListBoxItem Content="Imre"></ListBoxItem>
                <ListBoxItem Content="Tamás"></ListBoxItem>
                <ListBoxItem Content="Ilona"></ListBoxItem>
                <ListBoxItem Content="Katalin"></ListBoxItem>
                <ListBoxItem Content="Róbert"></ListBoxItem>
            </ListBox>
            <Button Width="150" Height="30" Margin="20 0 0 0" Content="Rendezés" Click="order_Click"></Button>
            <Button Width="150" Height="30" Margin="20 0 0 0" Content="Hozzáadás" Click="add_Click"></Button>
            <Label FontWeight="Bold" Content="Diák neve:"></Label>
            <TextBlock Width="150" Height="30" Name="newName"></TextBlock>
        </StackPanel>
    </Grid>
</Window>
