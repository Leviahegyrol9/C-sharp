<Window x:Class="WpfApp7.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp7"
        mc:Ignorable="d"
        Title="MainWindow" Height="180" Width="400">
    <Window.DataContext>
        <local:Adatok/>
    </Window.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" FontSize="20" Margin="5" Text="Aktuális dátum"></TextBlock>
            <TextBlock Grid.Row="1" Grid.Column="0" FontSize="20" Margin="5" Text="Születési dátum"></TextBlock>
            <TextBlock Grid.Row="2" Grid.Column="0" FontSize="20" Margin="5" Text="Kor"></TextBlock>
            <TextBlock Grid.Row="0" Grid.Column="1" FontSize="20" Margin="5" Text="{Binding Aktualis, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBlock>
            <TextBlock Grid.Row="1" Grid.Column="1" FontSize="20" Margin="5" Text="{Binding Szuletesi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBlock>
            <TextBox Grid.Row="2" Grid.Column="1" FontSize="20" Margin="5" IsReadOnly="True" Text="{Binding Kor, Mode=OneWay}"></TextBox>
        </Grid>
</Window>
