<Window x:Class="WpfApp9.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp9"
        mc:Ignorable="d"
        Title="MainWindow" Height="420" Width="600">
    <Window.DataContext>
        <local:Ertek/>
    </Window.DataContext>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"></RowDefinition>
            <RowDefinition Height="70"></RowDefinition>
            <RowDefinition Height="70"></RowDefinition>
            <RowDefinition Height="70"></RowDefinition>
            <RowDefinition Height="70"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Label FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Grid.ColumnSpan="2" Content="Befektetési kalkulátor"></Label>
        <Label Grid.Row="1" Grid.Column="0" FontStyle="Italic" Content="Befektetni kívánt összeg" FontSize="18" VerticalAlignment="Center"></Label>
        <Label Grid.Row="2" Grid.Column="0" FontStyle="Italic" Content="Éves kamatláb" FontSize="18" VerticalAlignment="Center"></Label>
        <Label Grid.Row="3" Grid.Column="0" FontStyle="Italic" Content="Lekötés időtartama" FontSize="18" VerticalAlignment="Center"></Label>
        <Label Grid.Row="4" Grid.Column="0" FontStyle="Italic" Content="Jövőbeli összeg" FontSize="18" VerticalAlignment="Center"></Label>

        <TextBox Grid.Row="1" Grid.Column="1" Width="200" Height="30" Text="{Binding Befektetett, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Row="2" Grid.Column="1" Width="200" Height="30" Text="{Binding Kamatlab, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Row="3" Grid.Column="1" Width="200" Height="30" Text="{Binding Ido, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Row="4" Grid.Column="1" Width="200" Height="30" Text="{Binding Osszeg, Mode=OneWay}" IsReadOnly="True"></TextBox>
        
    </Grid>
</Window>
