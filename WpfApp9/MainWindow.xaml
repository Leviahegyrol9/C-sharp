<Window x:Class="WpfApp9.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp9"
        mc:Ignorable="d"
        Title="MainWindow" Height="550" Width="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="290"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel>
            <Label Content="Állatorvosi nyilvántartás" FontSize="20" FontWeight="Bold"></Label>
            <ListBox Width="300" Height="200" HorizontalAlignment="Left" x:Name="lista"></ListBox>
        </StackPanel>
        <Label Grid.Row="1" Grid.Column="0" Content="Kezelt állatok száma:" FontSize="20" Margin="5"></Label>
        <Label Grid.Row="2" Grid.Column="0" Content="Átlagos testsúly:" FontSize="20" Margin="5"></Label>
        <Label Grid.Row="3" Grid.Column="0" Content="Átlagos életkor:" FontSize="20" Margin="5"></Label>
        <StackPanel Grid.Row="0" Grid.Column="1" Name="tb">
            <Label Content="Név: " FontSize="20" FontWeight="Bold"></Label>
            <TextBox x:Name="ujnev" Width="250" Height="30" HorizontalAlignment="Left"></TextBox>
            <Label Content="Súly (kg): " FontSize="20" FontWeight="Bold"></Label>
            <TextBox x:Name="ujsuly" Width="250" Height="30" HorizontalAlignment="Left"></TextBox>
            <Label Content="Életkor (év): " FontSize="20" FontWeight="Bold"></Label>
            <TextBox x:Name="ujev" Width="250" Height="30" HorizontalAlignment="Left"></TextBox>
            <Label Content="Fajta: " FontSize="20" FontWeight="Bold"></Label>
            <TextBox x:Name="ujfajta" Width="250" Height="30" HorizontalAlignment="Left"></TextBox>
        </StackPanel>
        <TextBlock Grid.Row="1" Grid.Column="1" Name="letszam"></TextBlock>
        <TextBlock Grid.Row="2" Grid.Column="1" Name="atlagsuly"></TextBlock>
        <TextBlock Grid.Row="3" Grid.Column="1" Name="atlagoskor"></TextBlock>
        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" HorizontalAlignment="Center" Orientation="Horizontal">
            <Button Content="Hozzáadás" Width="150" Height="30" Margin="10" Click="addClick"></Button>
            <Button Content="Lista ürítése" Width="150" Height="30" Margin="10" Click="clearClick"></Button>
            <Button Content="Átlagszámítás" Width="150" Height="30" Margin="10" Click="averageClick"></Button>
            <Button Content="Létszám meghatározás" Width="150" Height="30" Margin="10" Click="countClick"></Button>
        </StackPanel>
    </Grid>
</Window>
