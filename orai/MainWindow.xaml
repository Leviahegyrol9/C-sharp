<Window x:Class="orai.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:orai"
        mc:Ignorable="d"
        Title="MainWindow" Height="130" Width="280">
    <Grid>
        <StackPanel Margin="10" Orientation="Vertical">
            <WrapPanel>
                <TextBlock Text="Windows title" Margin="5"></TextBlock>
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Width="150"></TextBox>
            </WrapPanel>
            <WrapPanel>
                <TextBlock Text="Windows dimensions" Margin="5"></TextBlock>
                <TextBox Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}" Width="50"></TextBox>
                <TextBlock Text="*"></TextBlock>
                <TextBox Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}" Width="50"></TextBox>
            </WrapPanel>
        </StackPanel>
    </Grid>
</Window>
