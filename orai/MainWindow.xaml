<Window x:Class="orai.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:orai"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="650">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="400"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Label Content="Felújítás költségei" FontWeight="Bold" FontSize="30" Grid.ColumnSpan="2" HorizontalAlignment="Center"></Label>
        <ListBox Grid.Row="1" Width="300" Height="300" Name="list"></ListBox>
        <StackPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="Adatok betöltése" Click="GetData" Width="150" Height="25" Margin="10"></Button>
            <Button Content="Padlófajtánkénti statisztika" Click="Statistic" Width="150" Height="25" Margin="10"></Button>
            <Button Content="Színek száma" Click="Colors" Width="180" Height="25" Margin="10"></Button>
            <Button Content="Legnagyobb szoba" Click="BiggestRoom" Width="150" Height="25" Margin="10"></Button>
            <Button Content="Költségszámolások" Click="Calculate" Width="150" Height="25" Margin="10"></Button>
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Center">
            <Label Content="Költség (Ft):" FontSize="20"></Label>
            <TextBox Width="300" Height="25"></TextBox>
            <Button Content="Keresés" Click="Search" Width="200" Height="25" Margin="10"></Button>
        </StackPanel>
    </Grid>
</Window>
