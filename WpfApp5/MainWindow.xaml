<Window x:Class="WpfApp5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp5"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="350">
    <DockPanel Margin="10">
        <Label DockPanel.Dock="Top" Content="Egyszerű számológép" FontWeight="Bold" FontSize="14" Margin="10"></Label>
        <StackPanel>
            <Label Content="1. szám"></Label>
            <TextBox Width="250" Height="30" HorizontalAlignment="Left" Margin="10" Name="szam1"></TextBox>
            <Label Content="2. szám"></Label>
            <TextBox Width="250" Height="30" HorizontalAlignment="Left" Margin="10" Name="szam2"></TextBox>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                <Button Content="Összeadás" Width="100" Height="30" Margin="5" Name="osszeadas" Click="osszeadas_Click"></Button>
                <Button Content="Kivonás" Width="100" Height="30" Margin="5" Name="kivonas" Click="kivonas_Click"></Button>
                <Button Content="Törlés" Width="100" Height="30" Margin="5" Name="torles" Click="torles_Click"></Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Label Content="Eredmény: " FontWeight="Bold" Name="eredmeny"></Label>
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
