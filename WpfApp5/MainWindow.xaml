<Window x:Class="WpfApp5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp5"
        mc:Ignorable="d"
        Title="MainWindow" Height="200" Width="500">
    <Window.DataContext>
        <local:Autoadatok/>
    </Window.DataContext>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Label Content="Megtett távolság (km)" FontSize="20" Margin="5"></Label>
        <Label Grid.Row="1" Content="Felhasznált üzemanyag (l)" FontSize="20" Margin="5"></Label>
        <Label Grid.Row="2" Content="Üzemanyag fogyasztás (l / 100km)" FontSize="20" Margin="5"></Label>
        <TextBox Grid.Column="1" Margin="5" Text="{Binding Tav, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Column="1" Grid.Row="1" Margin="5" Text="{Binding Uzemanyag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Column="1" Grid.Row="2" Margin="5" IsReadOnly="True" Text="{Binding Fogyasztas, Mode=OneWay}"></TextBox>
    </Grid>
</Window>
