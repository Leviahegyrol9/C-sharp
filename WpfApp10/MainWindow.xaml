<Window x:Class="WpfApp10.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp10"
        mc:Ignorable="d"
        Title="MainWindow" Height="230" Width="500">
    <Window.DataContext>
        <local:Viz/>
    </Window.DataContext>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Vízóra állás előző hónapban" FontSize="20" Margin="5"></TextBlock>
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Vízóra állás aktuális hónapban" FontSize="20" Margin="5"></TextBlock>
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Vízdíj" FontSize="20" Margin="5"></TextBlock>
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Vízfogyasztás költsége" FontSize="20" Margin="5"></TextBlock>

        <TextBox Grid.Row="0" Grid.Column="1" Margin="5" Text="{Binding Elozo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="5" Text="{Binding Aktualis, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="5" Text="{Binding Vizdij, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Grid.Row="3" Grid.Column="1" Margin="5" IsReadOnly="True" Text="{Binding Koltseg, Mode=OneWay}"></TextBox>
    </Grid>
</Window>
