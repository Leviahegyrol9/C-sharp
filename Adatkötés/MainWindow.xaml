<Window x:Class="Orai.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Orai"
        mc:Ignorable="d"
        Title="MainWindow" Height="350" Width="500">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="100"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <TextBlock Text="First Name" Margin="10"></TextBlock>
        <TextBlock Grid.Row="1" Text="Last Name" Margin="10"></TextBlock>
        <TextBlock Grid.Row="2" Text="Class" Margin="10"></TextBlock>

        <TextBox Grid.Column="1" Margin="10" Text="{Binding FirstName}"></TextBox>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding LastName}" Margin="10"></TextBox>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Class}" Margin="10"></TextBox>

        <Button Grid.Row="3" Grid.Column="1" HorizontalAlignment="Left" Width="45" Height="45" Margin="0 12 0 9" Content="Next" Click="Button_Click"></Button>
    </Grid>
</Window>
