<Window x:Class="Nobel_díj.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Nobel_díj"
        mc:Ignorable="d"
        Title="MainWindow" Height="650" Width="600">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="400"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Grid.ColumnSpan="2" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"></Label>
        <ListBox Grid.Row="1" Grid.Column="0" Width="320" Height="300" Name="lista"></ListBox>
        <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center">
            <Button Content="Adatok betöltése" Width="100" Height="30" Margin="10" Click="betoltes_Click"></Button>
            <Button Content="Évenkénti statisztika" Width="100" Height="30" Margin="10" Click="statisztika_Click"></Button>
            <Button Content="Béke Nobel díjas szervezetek" Width="100" Height="30" Margin="10" Click="szervezetek_Click"></Button>
            <Button Content="Tipusonkénti statisztika" Width="100" Height="30" Margin="10" Click="statisztika2_Click"></Button>
            <Button Content="Orvosi Nobel díjak" Width="100" Height="30" Margin="10" Click="orvosi_Click"></Button>
            <Button Content="Első Nobel díjasok" Width="100" Height="30" Margin="10" Click="elsok_Click"></Button>
        </StackPanel>
        <Label Grid.Row="2" Grid.Column="0" Content="Név: " VerticalAlignment="Center"></Label>
        <TextBox Grid.Row="2" Grid.Column="0" Width="230" Height="30" Name="keres"></TextBox>
        <Button Grid.Row="2" Grid.Column="1" Content="Keresés" Width="150" Height="30" Name="kereses" Click="kereses_Click"></Button>
    </Grid>
</Window>
